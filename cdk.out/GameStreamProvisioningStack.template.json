  "GameStreamProvisioningMachine6F507EBE": {
   "Type": "AWS::StepFunctions::StateMachine",
   "Properties": {
    "DefinitionString": {
     "Fn::Join": [
      "",
      [
       "{\"StartAt\":\"CreateAppTask\",\"States\":{\"CreateAppTask\":{\"Next\":\"AssociateAppTask\",\"Retry\":[{\"ErrorEquals\":[\"Lambda.ClientExecutionTimeoutException\",\"Lambda.ServiceException\",\"Lambda.AWSLambdaException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":2,\"MaxAttempts\":6,\"BackoffRate\":2}],\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"ProvisioningFailed\"}],\"Type\":\"Task\",\"Comment\":\"Create GameLift Streams Application from S3 source\",\"InputPath\":\"$\",\"ResultPath\":\"$.AppDetails\",\"Resource\":\"",
       {
        "Fn::GetAtt": [
         "CreateAppFunction1153C4CD",
         "Arn"
        ]
       },
       "\"},\"AssociateAppTask\":{\"Next\":\"UpdateDbStatusTask\",\"Retry\":[{\"ErrorEquals\":[\"Lambda.ClientExecutionTimeoutException\",\"Lambda.ServiceException\",\"Lambda.AWSLambdaException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":2,\"MaxAttempts\":6,\"BackoffRate\":2}],\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"ProvisioningFailed\"}],\"Type\":\"Task\",\"Comment\":\"Associate Application with Stream Group\",\"ResultPath\":\"$.AssociationDetails\",\"Resource\":\"",
       {
        "Fn::GetAtt": [
         "AssociateAppFunctionD8A3C60F",
         "Arn"
        ]
       },
       "\",\"Parameters\":{\"ApplicationArn.$\":\"$.AppDetails.ApplicationArn\",\"submissionId.$\":\"$.submissionId\"}},\"UpdateDbStatusTask\":{\"Next\":\"ProvisioningSucceeded\",\"Retry\":[{\"ErrorEquals\":[\"Lambda.ClientExecutionTimeoutException\",\"Lambda.ServiceException\",\"Lambda.AWSLambdaException\",\"Lambda.SdkClientException\"],\"IntervalSeconds\":2,\"MaxAttempts\":6,\"BackoffRate\":2}],\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"ProvisioningFailed\"}],\"Type\":\"Task\",\"Comment\":\"Update DynamoDB submission status to READY\",\"ResultPath\":null,\"Resource\":\"",
       {
        "Fn::GetAtt": [
         "UpdateDbFunction67988D94",
         "Arn"
        ]
       },
       "\",\"Parameters\":{\"submissionId.$\":\"$.submissionId\",\"applicationArn.$\":\"$.AppDetails.ApplicationArn\",\"streamGroupId.$\":\"$.AssociationDetails.StreamGroupId\",\"status\":\"READY\"}},\"ProvisioningSucceeded\":{\"Type\":\"Succeed\",\"Comment\":\"GameLift provisioning completed successfully\"},\"ProvisioningFailed\":{\"Type\":\"Fail\",\"Comment\":\"GameLift provisioning failed\"}},\"TimeoutSeconds\":3600,\"Comment\":\"State machine to provision GameLift Streams application\"}"
      ]
     ]
