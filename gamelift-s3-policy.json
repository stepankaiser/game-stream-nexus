{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowGameLiftStreamsAccess",
      "Effect": "Allow",
      "Principal": {
        "Service": "gamelift.amazonaws.com"
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::game-builds-remangu",
        "arn:aws:s3:::game-builds-remangu/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "533267319964"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:gamelift:eu-central-1:533267319964:*"
        }
      }
    }
  ]
} 