{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "CommonJS",
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",

    /* Bundler mode */
    "moduleResolution": "node",
    "isolatedModules": false,
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "sourceMap": true
  },
  "include": [
    "vite.config.ts",
    "infra/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src"
  ]
}
